<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#12161A"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E2329"
        android:padding="14dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvSymbol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BTCUSDT"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Connecting Engine..."
            android:textColor="#0ECB81"
            android:textSize="20sp"
            android:fontFamily="monospace"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:background="#161A1E"
        android:layout_marginTop="2dp"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvChange"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="24h: --%"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#848E9C"/>

        <TextView
            android:id="@+id/tvHigh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="High: --"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#848E9C"/>

        <TextView
            android:id="@+id/tvLow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Low: --"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#848E9C"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MEMBER FUTURES CONTRACTS (400+ TARGETS)"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#848E9C"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/lvCryptoPairs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#1E2329"
        android:dividerHeight="1dp"
        android:background="#161A1E"/>
</LinearLayout>
